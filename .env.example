# ── Clavis — environment variables ──────────────────────────────────────
# Copy to .env.local and fill in. See docs/DEV_PLAN.md §2.

# Part 1 — OpenSanctions /match endpoint (sanctions + PEP). Provided to the team.
OPENSANCTIONS_API_KEY=
# Match scope / dataset: default | sanctions | bg_omnio_poi
OPENSANCTIONS_SCOPE=default

# Part 2 — Web search for adverse media (https://tavily.com, free tier: 1k credits/mo).
TAVILY_API_KEY=

# Part 2 — Anthropic LLM that powers the agent + adverse-media flagging.
ANTHROPIC_API_KEY=
